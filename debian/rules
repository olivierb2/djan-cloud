#!/usr/bin/make -f

%:
	dh $@

override_dh_dwz:
	echo "Bypass dh_dwz"

override_dh_strip:
	dh_strip --exclude=/site-packages/

override_dh_shlibdeps:
	dh_shlibdeps --exclude=/site-packages/

override_dh_strip_nondeterminism:
	dh_strip_nondeterminism --exclude=/site-packages/

override_dh_installsystemd:
	dh_installsystemd --name=djancloud-celery
	dh_installsystemd --name=djancloud-smtp
	dh_installsystemd --name=djancloud-imap
	dh_installsystemd
